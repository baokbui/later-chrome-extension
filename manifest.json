{
  "manifest_version": 3,
  "name": "Later",
  "version": "0.1.0",
  "description": "Park a tab with a reason. Get surfaced back to it when you said you'd return.",
  "permissions": ["storage", "alarms", "notifications", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save this tab for Later",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open Later to save the current tab"
    }
  }
}
